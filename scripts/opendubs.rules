# OpenDubs udev rules 
# Provides stable /dev symlinks for hardware devices used in the OpenDubs robot. 
# 
# To install: run scripts/create_udev_rules.sh 
# To verify: ls -l /dev/rplidar0 /dev/rplidar1 /dev/pixhawk 

# --- SLLIDAR A1 (Silicon Labs CP2102 USB-UART) --- 
# rplidar0 = physical port 1-4.1.1.1.1 (left/first port on hub) 
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", KERNELS=="1-4.1.1.1.1", MODE:="0666", SYMLINK+="rplidar0"

# rplidar1 = physical port 1-4.1.1.1.2 (right/second port on hub) 
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", KERNELS=="1-4.1.1.1.2", MODE:="0666", SYMLINK+="rplidar1"

# --- Pixhawk 2.4.8 / ArduPilot FCU (native USB, pid.codes VID) --- 
SUBSYSTEM=="tty", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="5741", MODE:="0666", SYMLINK+="pixhawk" 
