# OpenDubs udev rules
# Provides stable /dev symlinks for hardware devices used in the OpenDubs robot.
#
# To install: run scripts/create_udev_rules.sh
# To verify: ls -l /dev/rplidar /dev/pixhawk

# --- SLLIDAR A1 (Silicon Labs CP2102 USB-UART) ---
# Vendor: Silicon Labs (10c4), Product: CP210x (ea60)
KERNEL=="ttyUSB*", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", MODE:="0777", SYMLINK+="rplidar"

# --- Pixhawk 2.4.8 / ArduPilot FCU (native USB, pid.codes VID) ---
# Vendor: pid.codes (1209) — used by Pixhawk 2.4.8 clones
KERNEL=="ttyACM*", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="5741", MODE:="0666", SYMLINK+="pixhawk"